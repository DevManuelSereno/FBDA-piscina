// Prisma schema — Sistema de Ranking de Natação (FBDA)
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// NOTA: campos de "tipo fixo" (sexo, estilo de prova, status do resultado,
// papel do usuário, tipo de regra de pontuação) são modelados como String,
// não como `enum` do Prisma. SQLite (usado em dev) não suporta enums nativos;
// mantendo String em todo lugar, o mesmo schema funciona sem alterações em
// dev (SQLite) e produção (Postgres). A validação do conjunto de valores
// válidos fica a cargo do Zod na camada de aplicação.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Clube {
  id        String   @id @default(cuid())
  nome      String
  sigla     String?
  cidade    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  atletas Atleta[]

  @@unique([nome])
}

// Circuito: cada "planilha"/competição paralela do cliente (ex.: "Infantil a
// Sênior", "Master"). Categorias e competições pertencem a um único circuito
// — os rankings não se misturam entre circuitos.
model Circuito {
  id    String  @id @default(cuid())
  nome  String
  ordem Int     @default(0)
  ativo Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categorias      Categoria[]
  tiposCompeticao TipoCompeticao[]

  @@unique([nome])
}

// TipoCompeticao: o "tipo/nível" de uma competição dentro de um circuito
// (ex.: Concurso, Regional, Brasileiro de Categorias, Brasileiro Absoluto,
// Fita Azul — nomes reais dos grupos vistos nas planilhas do cliente).
// Determina se o lançamento é por colocação (grid de provas) ou manual
// (pontos digitados direto por competição — ver Etapa 11).
model TipoCompeticao {
  id              String @id @default(cuid())
  nome            String
  metodoPontuacao String // "COLOCACAO" | "MANUAL"
  // Rótulo de agrupamento para o relatório matriz (Etapa 12), ex.:
  // "CONCURSO", "CAMPEONATO", "REGIONAL", "BRASILEIRO_CATEGORIAS",
  // "BRASILEIRO_ABSOLUTO", "FITA_AZUL".
  grupoRelatorio  String
  ordem           Int    @default(0)

  circuitoId String
  circuito   Circuito @relation(fields: [circuitoId], references: [id])

  // Só relevante quando metodoPontuacao = COLOCACAO.
  regraPontuacaoId String?
  regraPontuacao   RegraPontuacao? @relation(fields: [regraPontuacaoId], references: [id])

  competicoes Competicao[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([circuitoId, nome])
}

model Categoria {
  id                String  @id @default(cuid())
  nome              String
  sexo              String // "M" | "F" | "MISTO"
  idadeMin          Int
  idadeMax          Int
  // Ordena a categoria dentro do circuito (ex.: INF1 < INF2 < ... < SR)
  // para listagens e o relatório matriz (Etapa 12).
  ordem             Int     @default(0)
  // Categorias como PCD/PRE (circuito Master) existem no cadastro mas não
  // devem ser atribuídas automaticamente por idade — ver lib/categoria.ts.
  autoClassificavel Boolean @default(true)

  circuitoId String
  circuito   Circuito @relation(fields: [circuitoId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resultados           Resultado[]
  pontuacoesCompeticao PontuacaoCompeticao[]

  @@unique([circuitoId, nome, sexo])
}

model Atleta {
  id             String   @id @default(cuid())
  nomeCompleto   String
  dataNascimento DateTime
  sexo           String // "M" | "F"
  ativo          Boolean  @default(true)
  // Número/código de inscrição do atleta na federação (coluna "N." nas
  // planilhas do cliente). Opcional, apenas informativo.
  numero         Int?

  clubeId String
  clube   Clube  @relation(fields: [clubeId], references: [id])

  resultados           Resultado[]
  pontuacoesCompeticao PontuacaoCompeticao[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clubeId])
}

model Prova {
  id        String @id @default(cuid())
  nome      String
  estilo    String // LIVRE | COSTAS | PEITO | BORBOLETA | MEDLEY
  distancia Int // metros
  piscina   String // "25m" | "50m"

  resultados Resultado[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([nome, distancia, estilo, piscina])
}

model Competicao {
  id        String   @id @default(cuid())
  nome      String
  data      DateTime
  local     String?
  temporada String?

  tipoCompeticaoId String
  tipoCompeticao   TipoCompeticao @relation(fields: [tipoCompeticaoId], references: [id])

  resultados           Resultado[]
  pontuacoesCompeticao PontuacaoCompeticao[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tipoCompeticaoId])
}

model Resultado {
  id String @id @default(cuid())

  atletaId String
  atleta   Atleta @relation(fields: [atletaId], references: [id], onDelete: Cascade)

  provaId String
  prova   Prova  @relation(fields: [provaId], references: [id], onDelete: Cascade)

  competicaoId String
  competicao   Competicao @relation(fields: [competicaoId], references: [id], onDelete: Cascade)

  // Categoria disputada — snapshot no momento do lançamento, para o
  // ranking permanecer estável mesmo se as faixas etárias mudarem depois.
  categoriaId String
  categoria   Categoria @relation(fields: [categoriaId], references: [id])

  tempoCentesimos Int? // null quando status != VALIDO
  colocacao       Int? // posição na prova; null quando DQ/DNS
  pontos          Float  @default(0)
  status          String @default("VALIDO") // VALIDO | DQ | DNS

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([atletaId, provaId, competicaoId])
  @@index([competicaoId, provaId])
  @@index([categoriaId])
}

// PontuacaoCompeticao: camada de rollup — 1 linha por atleta×competição,
// fonte única do ranking e do futuro relatório matriz (Etapa 12).
// COLOCACAO: derivada automaticamente da soma de Resultado.pontos daquele
// atleta na competição (ver lib/pontuacao-competicao.ts). MANUAL: digitada
// direto na tela /lancamento-pontos, sem Resultado nenhum por trás.
model PontuacaoCompeticao {
  id String @id @default(cuid())

  atletaId String
  atleta   Atleta @relation(fields: [atletaId], references: [id], onDelete: Cascade)

  competicaoId String
  competicao   Competicao @relation(fields: [competicaoId], references: [id], onDelete: Cascade)

  // Categoria disputada — mesmo raciocínio de snapshot do Resultado.
  categoriaId String
  categoria   Categoria @relation(fields: [categoriaId], references: [id])

  pontos Float  @default(0)
  origem String // "CALCULADO" | "MANUAL"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([atletaId, competicaoId])
  @@index([competicaoId])
  @@index([categoriaId])
}

model RegraPontuacao {
  id    String  @id @default(cuid())
  nome  String
  tipo  String // COLOCACAO | FINA
  ativo Boolean @default(false)

  posicoes        PontuacaoPosicao[]
  tiposCompeticao TipoCompeticao[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PontuacaoPosicao {
  id String @id @default(cuid())

  regraId String
  regra   RegraPontuacao @relation(fields: [regraId], references: [id], onDelete: Cascade)

  posicao Int
  pontos  Float

  @@unique([regraId, posicao])
}

model Usuario {
  id        String @id @default(cuid())
  email     String @unique
  senhaHash String
  nome      String
  papel     String @default("EDITOR") // ADMIN | EDITOR

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
