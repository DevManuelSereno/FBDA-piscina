# Copie este arquivo para .env e ajuste os valores.

# Banco de dados (SQLite em dev; troque para Postgres em produção)
DATABASE_URL="file:./dev.db"

# Auth.js (NextAuth v5) — chave de assinatura da sessão JWT.
# Gere uma nova para cada ambiente com: openssl rand -base64 32
AUTH_SECRET="troque-por-uma-chave-gerada"
